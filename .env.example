# YouTube Data API v3 — OAuth Desktop client credentials
# Download client_secret JSON from Google Cloud Console and put the path here,
# OR paste the values directly.
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_CLIENT_SECRETS_FILE=./data/client_secret.json

# Ollama
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b-instruct

# OpenRouter — active video generation provider (Pivot.6)
# Used for kwaivgi/kling-v3.0-std (and other video models)
# Get key from openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-

# Kling AI direct JWT — LEGACY (kept for reference, replaced by OpenRouter)
KLING_ACCESS_KEY=
KLING_SECRET_KEY=
